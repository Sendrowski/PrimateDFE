# annotate VCF with consequence types using bcftools
rule annotate_csq:
    input:
        vcf="resources/vcf/ingroup/population/{population}.biallelic.vcf.gz",
        ref=lambda w: f"resources/ref/{get_ref_from_pop(w.population)}.fasta",
        gff=lambda w: f"resources/gff/ncbi/{get_ref_from_pop(w.population)}.gff.gz"
    output:
        "results/vcf/ingroup/population/{population}.csq.vcf.gz"
    conda:
        "envs/bcftools.yaml"
    shell:
        """
        bcftools csq -f {input.ref} -g {input.gff} {input.vcf} --phase a -Oz -o {output}
        """

