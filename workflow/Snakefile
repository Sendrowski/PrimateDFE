        """

# filter out everything that is not a bi-allelic SNP
rule filter_biallelic_snps:
    input:
        '{path}.vcf.gz'
    output:
        '{path}.biallelic.vcf.gz'
    conda:
        'envs/bcftools.yaml'
    shell:
        """
        bcftools view {input} -m2 -M2 -v snps -i 'TYPE="snp"' -O z -o {output}
        """

rule create_sample_name_file_population:
    input:
        lambda w: f'results/vcf/ingroup/{get_ref_from_pop(w.population)}/{get_species_from_pop(w.population)}.vcf.gz'
    output:
        'results/stats/sample_names/{population}.csv'
    params:
        individuals=lambda w: ','.join(get_individuals_from_pop(w.population))
    conda:
        'envs/bcftools.yaml'
    shell:
        """
        bcftools view -s {params.individuals} --force-samples {input} 2>/dev/null \
        | bcftools query -l > {output} || true

        # Ensure output file exists even if empty
        touch {output}
        """

# concatenate sample name files into a single file
rule concatenate_sample_name_files:
    input:
        expand('results/stats/sample_names/{population}.csv', population=populations)
    output:
        'results/stats/sample_names/all_samples.csv'
    run:
        import pandas as pd
        from pathlib import Path

        dfs = []
        for f in input:
            pop = Path(f).stem  # {population}
            df = pd.read_csv(f, header=None, names=["sample"])
            df["population"] = pop
            dfs.append(df)

        out = pd.concat(dfs, ignore_index=True)
        out.to_csv(output[0], index=False)


# determine number of individuals per population
checkpoint determine_individuals_per_population:
    input:
        expand("results/stats/sample_names/{population}.csv",population=populations)
    output:
        "results/stats/sample_names/counts/population_counts.csv"
    conda:
        "envs/base.yaml"
    shell:
        """
        echo "population,n_individuals" > {output}
        for f in {input}; do
            pop=$(basename $f .csv)
            n=$(wc -l < $f)
            echo "$pop,$n" >> {output}
        done
        """


def get_pops(n: int, group: str = None) -> list:
    """
    Get populations with at least n haplotypes.
    """
    # path = checkpoints.determine_individuals_per_population.get().output[0]
    path = "results/stats/sample_names/counts/population_counts.csv"

    return Populations.get_pops(n,group,path)


