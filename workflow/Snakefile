# annotate ancestral allele
rule annotate_ancestral_allele:
    input:
        vcf="results/vcf/{ref}/{species}.degeneracy.existing_outgroups.vcf.gz",
        fasta="resources/ref/{ref}.fasta",
        counts="results/stats/sample_names/{species}.csv"
    output:
        vcf="results/vcf/{ref}/{species}.degeneracy.polarized.vcf.gz",
        ann="results/vcf/{ref}/{species}.degeneracy.polarized.ann.json",
        stats="results/vcf/{ref}/{species}.degeneracy.polarized.stats.csv",
        probs="results/graphs/vcf/{ref}/{species}.degeneracy.polarized.probs.png",
    params:
        ingroups=lambda w: get_individuals_from_pop(w.species),
        outgroups=lambda w: ingroup_outgroups[w.species],
        n_target_sites=lambda w: get_species_metadata(w.ref).REFERENCE_LENGTH / 50 * (2 / 3),
        n_ingroups=lambda w: min(len(pd.read_csv(f"results/stats/sample_names/{w.species}.csv",header=None) * 2),9),
        max_sites=10000
    resources:
        mem_mb=20000
    conda:
        "envs/base.yaml"
    script:
        "scripts/annotate_ancestral_allele.py"

# compute site frequency spectrum
rule compute_sfs:
    input:
        vcf=lambda w: f"results/vcf/{w.ref}/{get_species_from_pop(w.population)}.degeneracy.polarized.vcf.gz",
        gff="resources/gff/{ref}.gff.gz",
        fasta="resources/ref/{ref}.fasta"
    output:
        "results/sfs/{ref}/{population}/sfs.unfolded{opts}{n}.csv"
    params:
        n=lambda w: int(w.n),
        ingroups=lambda w: get_individuals_from_pop(w.population),
        n_target_sites=lambda w: get_species_metadata(w.ref).REFERENCE_LENGTH / 50 * (2 / 3),
        filter_bgc=lambda w: 'filter_bgc' in w.opts,
    conda:
        'envs/base.yaml'
    script:
        "scripts/compute_sfs.py"

# compute folded site frequency spectrum
