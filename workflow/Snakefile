# aggregate beneficial model comparisons across populations in a group
rule aggregate_beneficial_model_comparisons:
    input:
        lambda w: [f"results/dfe/{get_ref_from_pop(p)}/{p}/model_comparison/beneficial/{{folded}}.{{n}}.{{parametrization}}.{{eps}}.csv" for p in get_pops(w.n,w.group)]
    output:
        "results/dfe/{group}/model_comparison/beneficial/aggregate/{folded}.{n}.{parametrization}.{eps}.csv"
    params:
        populations=lambda w: get_pops(w.n,w.group)
    run:
        import pandas as pd

        dfs = []
        for infile, pop in zip(input,params.populations):
            df = pd.read_csv(infile)
            df.insert(0,"population",pop)
            dfs.append(df)

        pd.concat(dfs,ignore_index=True).to_csv(output[0],index=False)

