# plot joint DFE stat against Ne
rule plot_joint_DFE_against_Ne:
    input:
        json="results/dfe/{group}/joint/{ref}/{shared}/{folded}.{n}.{parametrization}.{sub_model}.{eps}.json",
        ne="results/stats/Ne/comp/original_ref/{group}/{n}.csv",
        pops="results/stats/sample_names/counts/population_counts.csv"
    output:
        "results/graphs/dfe_vs_Ne/{group}/joint/{ref}/{shared}/dfe_vs_Ne.{folded}.{n}.{parametrization}.{sub_model}.{eps}.png"
    params:
        populations=lambda w: get_pops(w.n,w.group),
        mode="joint",
        labels=lambda w: (
            get_pops(w.n,w.group)
            if w.group == 'Castellano'
            else [get_group_from_pop(p) for p in get_pops(w.n,w.group)]
        ),
        legend=True
    conda:
        'envs/base.yaml'
    script:
        "scripts/plot_joint_dfe_against_Ne.py"

