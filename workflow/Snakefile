# bgzip fasta file
rule bgzip_fasta:
    input:
        'resources/ref/{species}.fasta'
    output:
        'resources/ref/{species}.fasta.gz'
    conda:
        'envs/samtools.yaml'
    shell:
        """
        bgzip -c {input} > {output}
        """

# align outgroup ref to ingroup ref using minimap
rule align_minimap:
    input:
        ref="resources/ref/{ref}.fasta",
        query="resources/ref/{query}.fasta"
    output:
        "results/minimap2/{ref}/{query}.paf"
    conda:
        "envs/minimap.yaml"
    threads: 8
    resources:
        mem_mb=50000,
        runtime=1200
    shell:
        """
        minimap2 -x asm5 -c --secondary=no -t {threads} {input.ref} {input.query} > {output}
        """

