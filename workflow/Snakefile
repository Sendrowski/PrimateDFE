# create a BED file from a GFF file
rule create_exon_bed_from_gff:
    input:
        "resources/gff/{ref}.gff.gz"
    output:
        'results/annotation/{ref}/exons.bed'
    conda:
        'envs/samtools.yaml'
    shell:
        """
        bgzip -cd {input} | awk '$3 == "CDS"' | awk '{{OFS="\t"; print $1, $4-1, $5}}' > {output}
        """

# calculate total length of exons in a BED file
rule bed_total_length:
    input:
        "results/annotation/{ref}/exons.bed"
    output:
        "results/annotation/{ref}/exons.total_length.txt"
    conda:
        "envs/bedtools.yaml"
    shell:
        """
        bedtools sort -i {input} | bedtools merge -i - | awk '{{sum += $3 - $2}} END {{print sum}}' > {output}
        """

