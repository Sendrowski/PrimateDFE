# link reference fasta for species
rule link_fasta:
    input:
        lambda w: get_fasta_path(w.species)
    output:
        "resources/ref/{species}.fasta"
    conda:
        "envs/coreutils.yaml"
    shell:
        """
        ln -sr {input} {output}
        """

# download human reference genome
rule download_hg38:
    output:
        "resources/ref/Homo_sapiens.fasta"
    params:
        url="ftp://ftp.1000genomes.ebi.ac.uk/vol1/ftp/technical/reference/GRCh38_reference_genome/GRCh38_full_analysis_set_plus_decoy_hla.fa"
    conda:
        "envs/wget.yaml"
    shell:
        "wget '{params.url}' -O {output}"

# index a fasta file using samtools
checkpoint create_fai:
    input:
        "{path}.fasta"
    output:
        "{path}.fasta.fai"
    conda:
        "envs/samtools.yaml"
    shell:
        "samtools faidx {input}"

# index VCF or GFF file using tabix
rule create_tbi:
    input:
        '{path}.{ext}.gz'
    output:
        '{path}.{ext,vcf|gff}.gz.tbi'
    conda:
        'envs/tabix.yaml'
    shell:
        """
        tabix -p {wildcards.ext} {input}
        """

# download the hgdp VCF files
rule get_hgdp:
    output:
        'resources/hgdp/chr/{chr}.vcf.gz'
    params:
        url='https://ngs.sanger.ac.uk/production/hgdp/hgdp_wgs.20190516/hgdp_wgs.20190516.full.{chr}.vcf.gz'
    conda:
        "envs/wget.yaml"
    shell:
        "wget '{params.url}' -O {output}"

# only retain French samples
rule filter_hgdp_french:
    input:
