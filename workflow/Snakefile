# count synonymous and nonsynonymous mutations in the annotated VCF
rule count_syn_nonsyn:
    input:
        "results/vcf/ingroup/population/{population}.csq.vcf.gz"
    output:
        "results/stats/ns/ingroup/population/{population}.txt"
    conda:
        "envs/bcftools.yaml"
    shell:
        """
        bcftools query -f '%INFO/BCSQ\n' {input} \
        | tr ',' '\n' \
        | awk '
          /synonymous/ {{syn++}}
          /(missense|nonsense)/ {{nonsyn++}}
          END{{
            print "Synonymous:", syn;
            print "Nonsynonymous:", nonsyn;
            if (syn>0) printf "N/S: %.6f ", nonsyn/syn; else print "N/S: NA"
          }}' \
        > {output}
        """

# gather N/S ratios for all populations into a CSV file
rule gather_NS_ratio:
    input:
        txt=expand("results/stats/ns/ingroup/population/{population}.txt",population=populations)
    output:
        "results/stats/comp/ns/ingroup/population/NS.csv"
    conda:
        "envs/base.yaml"
    shell:
        """
        echo "population,ns" > {output}
        for f in {input.txt}; do
            species=$(basename $f .txt)
            ratio=$(grep "N/S" $f | awk '{{print $2}}')
            echo "$species,$ratio" >> {output}
        done
        """

# gather ancestral stats for all populations into a CSV file
rule gather_ancestral_stats:
    input:
        lambda w: [f"results/vcf/{get_ref_from_pop(p)}/{get_species_from_pop(p)}.degeneracy.polarized.stats.csv" for p
                   in get_pops(8,w.group)]
    output:
        "results/stats/comp/{group}/ancestral_stats.csv"
    params:
        populations=lambda w: get_pops(8,w.group)
    conda:
        "envs/base.yaml"
    shell:
        """
        echo "population,"$(head -n1 {input[0]}) > {output}
        i=0
        read -r -a pops <<< "{params.populations}"
        for f in {input}; do
            pop="${{pops[$i]}}"   # <-- escape braces for Snakemake
            tail -n +2 "$f" | awk -v p="$pop" 'BEGIN{{OFS=","}}{{print p,$0}}' >> {output}
            i=$((i+1))
        done
        """

# normalize VCF
