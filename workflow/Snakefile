# combine DFE inferred for all populations in a group
rule combine_dfes_for_group:
    input:
        lambda w: [f"results/dfe/{get_ref_from_pop(p)}/{p}/dfe.{{folded}}{{opts}}{{n}}.{{parametrization}}.{{sub_model}}.{{eps}}.dfe.json" for p in get_pops(max(int(w.n),8),w.group)]
    output:
        "results/dfe/{group}/dfe.{folded}{opts}{n}.{parametrization}.{sub_model}.{eps}.csv"
    params:
        populations=lambda w: get_pops(max(int(w.n),8),w.group)
    run:
        import pandas as pd

        rows = []

        for pop, file in zip(params.populations,input):
            with open(file) as f:
                content = f.read()

            rows.append({
                "population": pop,
                "json": content,
            })

        df = pd.DataFrame(rows)
        df.to_csv(output[0],index=False)

