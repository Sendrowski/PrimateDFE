def get_ref_from_species(species: str) -> str:
    """
    Map species to its reference.
    """
    genus = species.split('_')[0]
    df = pd.read_csv(f"resources/metadata/{genus}_individuals.csv",sep="\t")

    rows = df[df["BAM_FOLDER"].str.contains(species)]
    if rows.empty:
        raise ValueError(f"No reference entry found for species: {species}")

    return rows.iloc[0].REFERENCE_FOLDER.replace('_ssp','')


def get_ref_from_pop(pop: str) -> str:
    """
    Get reference name from pop name.
    """
    return get_ref_from_species(get_species_from_pop(pop))


def get_species_from_pop(pop: str) -> str:
    """
    Get species name from pop name.
    Population often contain a subspecies identifier after the second underscore,
    but they might also just be species names.
    """
    return '_'.join(pop.split('_')[:2])

def get_species_metadata(s: str) -> pd.Series:
    """
    Get metadata for a given species.
    """
    return species[species['SPECIES_BINOMIAL'] == s].iloc[0]


def get_fasta_path(species: str) -> str:
    """
    Get the reference fasta file path for a given species.
    """
    genus = species.split('_')[0]

    df = pd.read_csv(f"resources/metadata/{genus}_references.csv",sep="\t")

    # find the row for this species
    row = df.loc[df["REFERENCE_FOLDER"].str.contains(species)].iloc[0]

    ref_name = os.path.basename(row["FTP"]).replace('.gz','')

    return f"../primatediversity/data/gVCFs_recalling_10_12_2024/{row.REFERENCE_FOLDER}/ref/{ref_name}"


def get_gff_path(species: str) -> str:
    """
    Get the reference fasta file path for a given species.
    """
    # special GFF links
    gff_links = dict(
        Homo_sapiens='https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/release_48/gencode.v48.annotation.gff3.gz',
    )

    if species in gff_links:
        return gff_links[species]

    genus = species.split('_')[0]

    df = pd.read_csv(f"resources/metadata/{genus}_references.csv",sep="\t")

    row = df.loc[df["REFERENCE_FOLDER"].str.contains(species)].iloc[0]

    return re.sub(r'\.(fna|fasta)\.','.gff.',row.FTP)


