# assemble population summary table
rule assemble_pop_table:
    input:
        species_metadata="resources/Kuderna/species.csv",
        n_individuals="results/stats/sample_names/counts/population_counts.csv",
        ne="results/stats/Ne/comp/original_ref/{group}/{n}.csv",
        ns="results/stats/comp/ns/ingroup/population/NS.csv",
        spectra="results/sfs/comp/original_ref/{group}/sfs.unfolded.{n}.csv",
        ancestral_stats="results/stats/comp/{group}/ancestral_stats.csv",
        outgroup_stats='results/stats/comp/{group}/outgroup_stats.{n}.csv',
        dfes=[
            "results/dfe/{group}/joint/original_ref/S1+S2+S3/unfolded.8.discrete.del.noeps.json",
            "results/dfe/{group}/joint/original_ref/S1+S2+S3/folded.8.discrete.del.noeps.json",
            "results/dfe/{group}/joint/original_ref/S1+S2+S3+S4+S5/unfolded.8.discrete.full.noeps.json",
            "results/dfe/{group}/joint/original_ref/b+S_d/unfolded.8.gamma.del.noeps.json",
            "results/dfe/{group}/joint/original_ref/b+S_d+p_b+S_b/unfolded.8.gamma.full.noeps.json"
        ]
    output:
        "results/tables/population_summary/{group}/population_summary.{n}.csv"
    params:
        populations=lambda w: get_pops(w.n,w.group),
        outgroups=ingroup_outgroups,
        references=lambda w: {p: get_ref_from_pop(p) for p in get_pops(w.n,w.group)},
        species=lambda w: {p: get_species_from_pop(p) for p in get_pops(w.n,w.group)},
        dfe_types=[
            "discrete_8_deleterious_noeps",
            "discrete_8_deleterious_noeps_folded",
            "discrete_8_full_noeps",
            "dfe_gamma_8_deleterious_noeps",
            "dfe_gamma_8_full_noeps"
        ]
    conda:
        "envs/base.yaml"
    script:
        "scripts/assemble_pop_table.py"

