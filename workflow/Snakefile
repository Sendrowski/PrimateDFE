# link the input VCF files
rule link_ingroup_vcf:
    input:
        '../primatediversity/data/gVCFs_recalling_10_12_2024/{species}_ssp/filteredVCF/bcf_step1/{species}_ssp_all_chr.sorted.bcf'
    output:
        'resources/vcf/ingroup/{species}.vcf.gz'
    conda:
        'envs/bcftools.yaml'
    shell:
        """
        bcftools view {input} | bgzip -c > {output}
        """

